# Configuración del sistema E14 Fraud Detector
# Editar según el entorno (dev / staging / prod)

# === ENTORNO ===
ENV=development
DEBUG=true

# === SERVIDOR ===
HOST=0.0.0.0
PORT=8700

# === NVIDIA NIM ===
# API Key para NVIDIA NIM (VLM Llama 3.2-90B Vision)
# Rotación automática: 3 keys disponibles, 37 req/min límite
NVIDIA_API_KEY=your_nvidia_api_key_here
NVIDIA_API_KEY_2=your_nvidia_api_key_2_here
NVIDIA_API_KEY_3=your_nvidia_api_key_3_here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# === RATE LIMITING ===
# Downloads desde Registraduría (req/s por IP)
DOWNLOAD_RATE_LIMIT=8

# === BASE DE DATOS ===
# SQLite para desarrollo
DATABASE_URL=sqlite:///data/e14_audit.db

# PostgreSQL para producción (Railway/Supabase)
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# === REDIS (Celery Broker) ===
# REDIS_URL=redis://localhost:6379/0

# === MINIO (Object Storage) ===
# MINIO_ENDPOINT=localhost:9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=e14-pdfs
